{
  "extends": "@react-native/typescript-config",
  "compilerOptions": {
    "baseUrl": ".",
    "esModuleInterop": true,
    "allowSyntheticDefaultImports": true,
    "paths": {
      "@common/*": ["../src/common/*"]
    }
  },
  "include": ["**/*.ts", "**/*.tsx", "src/@types/**/*", "../src/common/**/*"],
  "exclude": ["**/node_modules", "**/Pods"]
}
